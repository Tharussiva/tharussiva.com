# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Sanity — find these in sanity.io/manage → your project
VITE_SANITY_PROJECT_ID=muqh40po
VITE_SANITY_DATASET=production

# Sanity write token — for the migration script ONLY, never used in the site
# Create at: sanity.io/manage → your project → API → Tokens → Add API token (Editor role)
SANITY_WRITE_TOKEN=your_write_token_here

# Cloudflare R2 — the public URL of your R2 bucket
# Format: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
# or your custom domain if you set one on the bucket
VITE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
